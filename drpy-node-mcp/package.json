{
  "name": "drpy-node-mcp",
  "version": "1.0.0",
  "description": "MCP server for drpy-node",
  "main": "index.js",
  "type": "module",
  "bin": {
    "drpy-node-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/sync-version.js && rollup -c && mcpb pack",
